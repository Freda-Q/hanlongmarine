---
import ContentLayout from "../layouts/ContentLayout.astro";
---

<ContentLayout
  title="Downloads | Hanlong Marine Equipment"
  description="Access brochure and datasheet download columns for Hanlong marine and loading equipment."
  eyebrow="Downloads"
  heroTitle="Brochure and Datasheet Center"
  heroDescription="The downloads column is reserved for product catalogs, brochures and technical datasheets. It acts as a high-intent lead capture area."
>
  <section class="mx-auto max-w-7xl px-6 py-20 lg:px-10">
    <div class="grid gap-6 md:grid-cols-2">
      <article class="tech-card p-8">
        <div class="card-corner tl"></div>
        <div class="card-corner tr"></div>
        <div class="card-corner bl"></div>
        <div class="card-corner br"></div>
        <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-primary">Product Catalog</p>
        <h2 class="mt-4 font-display text-3xl font-bold text-white">PDF Brochure</h2>
        <p class="mt-4 text-sm leading-8 text-muted">Reserved for the main English product catalog and company brochure.</p>
      </article>
      <article class="tech-card p-8">
        <div class="card-corner tl"></div>
        <div class="card-corner tr"></div>
        <div class="card-corner bl"></div>
        <div class="card-corner br"></div>
        <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-primary">Technical Datasheets</p>
        <h2 class="mt-4 font-display text-3xl font-bold text-white">Datasheets & Drawings</h2>
        <p class="mt-4 text-sm leading-8 text-muted">Reserved for MLA, truck loading, QRH, MLMS and BAS technical download entries.</p>
      </article>
    </div>
  </section>
</ContentLayout>
