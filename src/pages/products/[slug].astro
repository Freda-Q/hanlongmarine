---
import ContentLayout from "../../layouts/ContentLayout.astro";
import { productPages } from "../../data/site";

export function getStaticPaths() {
  return productPages.map((item) => ({
    params: { slug: item.slug },
    props: { item }
  }));
}

const { item } = Astro.props;
---

<ContentLayout
  title={`${item.title} | Hanlong Marine Equipment`}
  description={item.description}
  eyebrow={item.category}
  heroTitle={item.title}
  heroDescription={item.description}
>
  <section class="mx-auto max-w-7xl px-6 py-20 lg:px-10">
    <div class="tech-card p-8 lg:p-10">
      <div class="card-corner tl"></div>
      <div class="card-corner tr"></div>
      <div class="card-corner bl"></div>
      <div class="card-corner br"></div>
      <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-primary">Column Placeholder</p>
      <p class="mt-5 max-w-3xl text-sm leading-8 text-muted">
        This page is reserved for the detailed product content migration. The site structure is now aligned with the planned column system and ready for deeper product-page buildout.
      </p>
    </div>
  </section>
</ContentLayout>
