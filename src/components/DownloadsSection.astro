---
import SectionHeading from "./SectionHeading.astro";
import { downloadResources } from "../data/home";
---

<section id="downloads" class="bg-[#020617] py-24 text-white">
  <div class="mx-auto grid max-w-[1320px] gap-16 px-6 lg:grid-cols-2 lg:px-10">
    <div>
      <SectionHeading
        eyebrow="Resource Center"
        title="Technical Documentation & Product Resources"
        description="Download product catalogs, technical specifications, certifications and engineering drawings in a cleaner lead-capture flow."
      />

      <div class="mt-10 grid gap-[3px] sm:grid-cols-2">
        {downloadResources.map((item) => (
          <article class="border border-white/10 bg-[#1E3E62]/30 p-6 [clip-path:polygon(0_0,calc(100%-16px)_0,100%_16px,100%_100%,0_100%)] transition hover:border-[#00D2FF]/35 hover:bg-[#1E3E62]/55">
            <div class="text-3xl">{item.icon}</div>
            <h3 class="mt-4 font-display text-xl font-semibold text-[#E2E8F0]">{item.title}</h3>
            <p class="mt-2 text-sm leading-6 text-[#94A3B8]">{item.description}</p>
            <div class="mt-4 flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.14em] text-[#00D2FF]">
              <span>Download PDF</span>
              <span>→</span>
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="border border-white/10 bg-[#1E3E62]/20 p-8 [clip-path:polygon(0_0,calc(100%-24px)_0,100%_24px,100%_100%,0_100%)]">
      <h3 class="font-display text-3xl font-bold text-[#E2E8F0]">Access Full Documentation</h3>
      <p class="mt-2 text-sm leading-7 text-[#94A3B8]">Provide your contact details to access the complete technical library.</p>

      <form class="mt-8 space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <label class="block">
            <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-[#94A3B8]">First Name *</span>
            <input type="text" class="mt-2 w-full border border-white/10 bg-[#0B192C]/60 px-4 py-3 text-sm text-[#E2E8F0] outline-none focus:border-[#00D2FF]" placeholder="John" />
          </label>
          <label class="block">
            <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-[#94A3B8]">Last Name *</span>
            <input type="text" class="mt-2 w-full border border-white/10 bg-[#0B192C]/60 px-4 py-3 text-sm text-[#E2E8F0] outline-none focus:border-[#00D2FF]" placeholder="Smith" />
          </label>
        </div>
        <label class="block">
          <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-[#94A3B8]">Business Email *</span>
          <input type="email" class="mt-2 w-full border border-white/10 bg-[#0B192C]/60 px-4 py-3 text-sm text-[#E2E8F0] outline-none focus:border-[#00D2FF]" placeholder="john.smith@company.com" />
        </label>
        <label class="block">
          <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-[#94A3B8]">Company *</span>
          <input type="text" class="mt-2 w-full border border-white/10 bg-[#0B192C]/60 px-4 py-3 text-sm text-[#E2E8F0] outline-none focus:border-[#00D2FF]" placeholder="Your Company Name" />
        </label>
        <label class="block">
          <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-[#94A3B8]">Job Title</span>
          <input type="text" class="mt-2 w-full border border-white/10 bg-[#0B192C]/60 px-4 py-3 text-sm text-[#E2E8F0] outline-none focus:border-[#00D2FF]" placeholder="Engineering Manager" />
        </label>
        <button type="button" class="inline-flex w-full items-center justify-center gap-2 bg-[#00D2FF] px-6 py-4 font-display text-sm font-semibold uppercase tracking-[0.14em] text-[#1565C0] hover:shadow-[0_0_24px_rgba(0,210,255,0.25)]">
          <span>Download Now</span>
        </button>
      </form>
    </div>
  </div>
</section>
