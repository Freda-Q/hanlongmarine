---
const nav = [
  ['Home', '/'],
  ['Products', '/products/'],
  ['Engineering', '/engineering-strength/'],
  ['Case Studies', '/case-studies/'],
  ['Downloads', '/downloads/'],
  ['Contact / RFQ', '/contact/']
];
---
<header class="sticky top-0 z-50 border-b border-cyan/15 bg-abyss/82 backdrop-blur-xl">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <a href="/" class="group flex items-center gap-3" aria-label="Hanlong home">
      <span class="grid h-10 w-10 place-items-center border border-cyan/40 bg-cyan/10 font-display text-lg font-bold text-cyan shadow-glow">HL</span>
      <span>
        <span class="block font-display text-lg font-bold uppercase tracking-[0.18em] text-silver">Hanlong</span>
        <span class="block text-xs uppercase tracking-[0.24em] text-muted">Petrochemical Equipment</span>
      </span>
    </a>
    <nav class="hidden items-center gap-6 lg:flex">
      {nav.map(([label, href]) => (
        <a class="text-sm font-medium text-muted transition hover:text-cyan" href={href}>{label}</a>
      ))}
    </nav>
    <a href="/contact/" class="scanline clip-angle border border-cyan/40 bg-cyan/10 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-cyan transition hover:scale-[.98] hover:bg-cyan/15">Request RFQ</a>
  </div>
  <nav class="flex gap-4 overflow-x-auto border-t border-cyan/10 px-4 py-3 text-sm lg:hidden">
    {nav.map(([label, href]) => (
      <a class="shrink-0 text-muted hover:text-cyan" href={href}>{label}</a>
    ))}
  </nav>
</header>
