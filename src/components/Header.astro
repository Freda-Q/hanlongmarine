---
import { topLevelPages } from "../data/home";
const BASE_URL = import.meta.env.BASE_URL;
---

<header class="sticky top-0 z-50 border-b border-primary/10 bg-background/90 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-10">
    <a href={BASE_URL} class="flex items-center gap-4">
      <div class="flex h-10 w-10 rotate-45 items-center justify-center border border-primary">
        <span class="-rotate-45 font-display text-base font-bold tracking-[0.1em] text-primary">H</span>
      </div>
      <div class="flex flex-col">
        <span class="font-display text-lg font-bold tracking-[0.24em] text-white">HANLONG</span>
        <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-primary">Marine Systems</span>
      </div>
    </a>

    <nav class="hidden items-center gap-7 md:flex">
      {topLevelPages.map((item) => (
        <a href={item.href} class="font-display text-xs uppercase tracking-[0.2em] text-muted transition hover:text-white">
          {item.label}
        </a>
      ))}
    </nav>

    <a
      href="https://wa.me/8613921967776"
      target="_blank"
      rel="noopener noreferrer"
      class="hidden border border-primary px-4 py-2 font-display text-xs font-semibold uppercase tracking-[0.18em] text-primary transition hover:bg-primary hover:text-background lg:inline-flex"
    >
      Request a Quote
    </a>
  </div>

  <div class="border-t border-primary/10 px-6 py-3 md:hidden">
    <nav class="flex gap-5 overflow-x-auto">
      {topLevelPages.map((item) => (
        <a href={item.href} class="shrink-0 font-display text-[11px] uppercase tracking-[0.18em] text-muted transition hover:text-white">
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
