---
import { topLevelPages } from "../data/home";
const BASE_URL = import.meta.env.BASE_URL;
---

<header class="sticky top-0 z-50 border-b border-primary/10 bg-background/90 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-3 lg:px-10 lg:py-4">
    <a href={BASE_URL} class="flex items-center">
      <img src={`${BASE_URL}assets/grand-logo-transparent.png`} alt="Grand logo" class="h-12 w-auto object-contain md:h-14" />
    </a>

    <nav class="hidden items-center gap-7 md:flex">
      {topLevelPages.map((item) => (
        <a href={item.href} class="font-display text-xs uppercase tracking-[0.2em] text-muted transition hover:text-white">
          {item.label}
        </a>
      ))}
    </nav>

    <a
      href="https://wa.me/8613921967776"
      target="_blank"
      rel="noopener noreferrer"
      class="hidden border border-primary px-4 py-2 font-display text-xs font-semibold uppercase tracking-[0.18em] text-primary transition hover:bg-primary hover:text-background lg:inline-flex"
    >
      Request a Quote
    </a>

    <details class="group relative md:hidden">
      <summary
        class="flex h-10 w-10 cursor-pointer list-none items-center justify-center border border-primary/30 text-primary transition hover:border-primary"
        aria-label="Open navigation menu"
      >
        <span class="relative h-3.5 w-5">
          <span class="absolute left-0 top-0 h-px w-5 bg-current transition group-open:top-[7px] group-open:rotate-45"></span>
          <span class="absolute left-0 top-[7px] h-px w-5 bg-current transition group-open:opacity-0"></span>
          <span class="absolute left-0 top-[14px] h-px w-5 bg-current transition group-open:top-[7px] group-open:-rotate-45"></span>
        </span>
      </summary>

      <nav class="absolute right-0 top-12 z-50 min-w-56 border border-primary/20 bg-background/95 p-4 shadow-2xl shadow-black/35 backdrop-blur-md">
        <div class="flex flex-col gap-3">
          {topLevelPages.map((item) => (
            <a href={item.href} class="font-display text-xs uppercase tracking-[0.18em] text-muted transition hover:text-white">
              {item.label}
            </a>
          ))}
          <a
            href="https://wa.me/8613921967776"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-2 border border-primary px-4 py-3 text-center font-display text-xs font-semibold uppercase tracking-[0.16em] text-primary transition hover:bg-primary hover:text-background"
          >
            Request a Quote
          </a>
        </div>
      </nav>
    </details>
  </div>
</header>
