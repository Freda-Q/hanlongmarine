---
import { heroStats } from "../data/home";
const BASE_URL = import.meta.env.BASE_URL;
---

<section class="relative overflow-hidden bg-background pt-16 md:pt-24">
  <div class="hero-scan"></div>
  <div class="absolute inset-0">
    <video
      autoplay
      loop
      muted
      playsinline
      preload="auto"
      class="h-full w-full object-cover object-center opacity-45"
    >
      <source src={`${BASE_URL}assets/hero_bg_video.mp4`} type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-r from-background/78 via-background/42 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-background/72 via-transparent to-background/18"></div>
  </div>

  <div class="relative mx-auto grid h-[56svh] min-h-[460px] max-h-[560px] max-w-7xl gap-12 px-6 pb-8 pt-6 md:min-h-[82vh] md:max-h-none md:pb-14 md:pt-10 lg:grid-cols-12 lg:items-center lg:px-10">
    <div class="lg:col-span-7">
      <div class="flex items-center gap-3 md:gap-4">
        <div class="hidden h-px w-10 bg-primary md:block"></div>
        <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-primary md:tracking-[0.3em]">
          <span class="md:hidden">Marine Terminal Equipment</span>
          <span class="hidden md:inline">Engineered for Safety. Built for Performance.</span>
        </p>
      </div>

      <h1 class="mt-5 flex flex-col gap-1 font-display text-[34px] font-bold uppercase leading-[1] sm:text-6xl lg:text-7xl lg:leading-[0.92]">
        <span class="font-light text-muted">Fluid Transfer</span>
        <span class="whitespace-nowrap text-white"><span class="text-primary">&amp; Mooring</span> Systems</span>
      </h1>

      <div class="my-5 hidden h-0.5 w-24 bg-gradient-to-r from-primary to-transparent md:block"></div>

      <p class="mt-5 max-w-md text-sm leading-7 text-muted sm:text-base md:mt-0 md:max-w-xl md:leading-8">
        <span class="md:hidden">Engineered loading, mooring and berthing systems for marine terminals.</span>
        <span class="hidden md:inline">Engineered for safety and built for reliability, our integrated systems keep marine and terminal operations moving.</span>
      </p>

      <div class="mt-7 flex flex-col gap-4 sm:flex-row md:mt-8">
        <a
          href="#products"
          class="inline-flex items-center justify-center border border-primary bg-primary px-6 py-3.5 font-display text-xs font-semibold uppercase tracking-[0.16em] text-[#1565C0] transition hover:bg-primary/90 md:px-8 md:py-4 md:tracking-[0.2em]"
        >
          Explore Products
        </a>
        <a
          href={`${BASE_URL}case-studies/`}
          class="hidden items-center justify-center border border-primary/30 bg-transparent px-8 py-4 font-display text-xs font-semibold uppercase tracking-[0.2em] text-[#7adfff] transition hover:border-primary hover:bg-primary/10 sm:inline-flex"
        >
          View Solutions
        </a>
      </div>
    </div>

    <div class="hidden lg:col-span-5 lg:flex lg:flex-col lg:items-end lg:gap-8 lg:text-right">
      {heroStats.map((item) => (
        <div class="border-r-2 border-primary pr-5">
          <div class="font-display text-4xl font-bold leading-none text-white">{item.value}</div>
          <div class="mt-1 font-mono text-[9px] uppercase tracking-[0.22em] text-white/65">{item.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
