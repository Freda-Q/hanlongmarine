---
const { eyebrow, title, description, tone = "dark" } = Astro.props;
const titleClass = tone === "light" ? "text-slate-800" : "text-white";
const descriptionClass = tone === "light" ? "text-slate-600" : "text-muted";
---

<div class="max-w-3xl">
  <div class="flex items-center gap-4">
    <div class="h-px w-10 bg-primary"></div>
    <p class="font-mono text-[10px] uppercase tracking-[0.28em] text-primary">{eyebrow}</p>
  </div>
  <h2 class:list={["mt-4 font-display text-4xl font-bold uppercase leading-none sm:text-5xl", titleClass]}>
    {title}
  </h2>
  {description && <p class:list={["mt-5 text-sm leading-8 sm:text-base", descriptionClass]}>{description}</p>}
</div>
