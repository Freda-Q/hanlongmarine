---
const { eyebrow, title, description, tone = "dark" } = Astro.props;
const titleClass = tone === "light" ? "text-slate-800" : "text-white";
const descriptionClass = tone === "light" ? "text-slate-600" : "text-muted";
---

<div class="max-w-3xl">
  <div class="flex items-center gap-3 sm:gap-4">
    <div class="h-px w-7 bg-primary sm:w-10"></div>
    <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-primary sm:tracking-[0.28em]">{eyebrow}</p>
  </div>
  <h2 class:list={["mt-3 font-display text-[1.85rem] font-bold uppercase leading-[1.05] sm:mt-4 sm:text-[3rem] sm:leading-[1.02]", titleClass]}>
    {title}
  </h2>
  {description && <p class:list={["mt-3 text-[13px] leading-6 sm:mt-4 sm:text-[15px] sm:leading-7", descriptionClass]}>{description}</p>}
</div>
