---
const { eyebrow, title, copy } = Astro.props;
---
<div class="max-w-3xl">
  {eyebrow && <p class="font-display text-sm font-bold uppercase tracking-[0.28em] text-cyan">{eyebrow}</p>}
  <h2 class="mt-3 font-display text-3xl font-bold uppercase tracking-[0.04em] text-silver sm:text-5xl">{title}</h2>
  {copy && <p class="mt-5 text-base leading-8 text-muted sm:text-lg">{copy}</p>}
</div>
