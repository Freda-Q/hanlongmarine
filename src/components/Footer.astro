---
import { certifications, contactInfo, topLevelPages } from "../data/home";
const BASE_URL = import.meta.env.BASE_URL;
---

<footer class="border-t border-white/10 bg-[#020617] py-20 text-white">
  <div class="mx-auto max-w-[1320px] px-6 lg:px-10">
    <div class="grid gap-14 lg:grid-cols-[2fr_1fr_1fr_1fr]">
      <div>
        <img src={`${BASE_URL}assets/grand-logo-transparent.png`} alt="Grand logo" class="h-20 w-auto object-contain" />
        <p class="mt-5 max-w-md text-sm leading-7 text-[#94A3B8]">
          Professional manufacturer of marine loading systems, truck loading arms, mooring safety equipment and terminal engineering solutions.
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          {certifications.map((item) => (
            <span class="border border-white/10 bg-[#1E3E62]/35 px-3 py-1 font-mono text-[10px] uppercase tracking-[0.12em] text-[#94A3B8]">
              {item}
            </span>
          ))}
        </div>
      </div>

      <div>
        <h3 class="font-display text-sm font-semibold uppercase tracking-[0.12em] text-[#E2E8F0]">Quick Links</h3>
        <div class="mt-5 flex flex-col gap-3">
          {topLevelPages.map((item) => (
            <a href={item.href} class="text-sm text-[#94A3B8] no-underline hover:text-[#00D2FF]">{item.label}</a>
          ))}
        </div>
      </div>

      <div>
        <h3 class="font-display text-sm font-semibold uppercase tracking-[0.12em] text-[#E2E8F0]">Products</h3>
        <div class="mt-5 flex flex-col gap-3">
          <a href={`${BASE_URL}products/`} class="text-sm text-[#94A3B8] no-underline hover:text-[#00D2FF]">Marine Fluid Transfer</a>
          <a href={`${BASE_URL}products/`} class="text-sm text-[#94A3B8] no-underline hover:text-[#00D2FF]">Land Fluid Transfer</a>
          <a href={`${BASE_URL}products/`} class="text-sm text-[#94A3B8] no-underline hover:text-[#00D2FF]">Safe Mooring Systems</a>
          <a href={`${BASE_URL}products/`} class="text-sm text-[#94A3B8] no-underline hover:text-[#00D2FF]">Berthing Aid Systems</a>
        </div>
      </div>

      <div>
        <h3 class="font-display text-sm font-semibold uppercase tracking-[0.12em] text-[#E2E8F0]">Contact</h3>
        <div class="mt-5 space-y-3 text-sm text-[#94A3B8]">
          <p>{contactInfo.company}</p>
          <p>{contactInfo.address}</p>
          <p>{contactInfo.mobile}</p>
          <p><a href="mailto:sales@hanlongsz.cn" class="hover:text-[#00D2FF]">{contactInfo.email}</a></p>
        </div>
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-5 border-t border-white/10 pt-6 text-sm text-[#94A3B8] sm:flex-row sm:items-center sm:justify-between">
      <p>© 2026 Hanlong Petrochemical Equipment. All rights reserved.</p>
      <div class="flex gap-3">
        <a href="#" class="flex h-9 w-9 items-center justify-center border border-white/10 bg-[#1E3E62]/35 text-[#94A3B8] no-underline hover:border-[#00D2FF]/30 hover:text-[#00D2FF]">in</a>
        <a href="#" class="flex h-9 w-9 items-center justify-center border border-white/10 bg-[#1E3E62]/35 text-[#94A3B8] no-underline hover:border-[#00D2FF]/30 hover:text-[#00D2FF]">▶</a>
        <a href="#" class="flex h-9 w-9 items-center justify-center border border-white/10 bg-[#1E3E62]/35 text-[#94A3B8] no-underline hover:border-[#00D2FF]/30 hover:text-[#00D2FF]">✉</a>
      </div>
    </div>
  </div>
</footer>
