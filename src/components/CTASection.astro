---
import SectionHeading from "./SectionHeading.astro";
import { contactInfo, rfqHighlights } from "../data/home";
---

<section id="contact" class="bg-[#132636] py-24 text-white">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <SectionHeading
          eyebrow="Get in Touch"
          title="Send Us Your RFQ"
          description="Tell us about your project requirements and our team will provide a tailored solution for your operations."
        />

        <div class="mt-8 space-y-5">
          {rfqHighlights.map((item) => (
            <div class="flex gap-4">
              <div class="mt-1 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-primary/25 bg-white/5">
                <div class="h-3 w-3 rounded-full bg-primary"></div>
              </div>
              <div>
                <h3 class="font-display text-sm font-bold uppercase tracking-[0.12em] text-white">{item.title}</h3>
                <p class="mt-2 text-sm leading-7 text-white/70">{item.description}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-8 border-t border-white/10 pt-6 text-sm leading-8 text-white/70">
          <p class="font-semibold text-white">{contactInfo.company}</p>
          <p>{contactInfo.address}</p>
          <p>{contactInfo.tel}</p>
          <p>{contactInfo.mobile}</p>
          <p>{contactInfo.fax}</p>
          <p>{contactInfo.email}</p>
        </div>
      </div>

      <div class="border border-white/10 bg-[#0c1b29] p-8 shadow-[0_28px_80px_rgba(2,8,23,0.42)]">
        <div class="card-corner tl"></div>
        <div class="card-corner tr"></div>
        <div class="card-corner bl"></div>
        <div class="card-corner br"></div>

        <form class="space-y-5">
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block">
              <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-white/55">Full Name</span>
              <input type="text" class="mt-2 w-full border border-white/10 bg-[#112537] px-4 py-3 text-sm text-white outline-none placeholder:text-white/30 focus:border-primary" placeholder="John Doe" />
            </label>
            <label class="block">
              <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-white/55">Company</span>
              <input type="text" class="mt-2 w-full border border-white/10 bg-[#112537] px-4 py-3 text-sm text-white outline-none placeholder:text-white/30 focus:border-primary" placeholder="Your company" />
            </label>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block">
              <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-white/55">Email</span>
              <input type="email" class="mt-2 w-full border border-white/10 bg-[#112537] px-4 py-3 text-sm text-white outline-none placeholder:text-white/30 focus:border-primary" placeholder="john@company.com" />
            </label>
            <label class="block">
              <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-white/55">Phone</span>
              <input type="text" class="mt-2 w-full border border-white/10 bg-[#112537] px-4 py-3 text-sm text-white outline-none placeholder:text-white/30 focus:border-primary" placeholder="Your phone number" />
            </label>
          </div>

          <label class="block">
            <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-white/55">Project Type / Application</span>
            <select class="mt-2 w-full border border-white/10 bg-[#112537] px-4 py-3 text-sm text-white outline-none focus:border-primary">
              <option>Select an option</option>
              <option>Marine Fluid Transfer</option>
              <option>Land Fluid Transfer</option>
              <option>Safe Mooring Systems</option>
              <option>Berthing Aid Systems</option>
            </select>
          </label>

          <label class="block">
            <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-white/55">Project Details / Requirements</span>
            <textarea class="mt-2 min-h-36 w-full border border-white/10 bg-[#112537] px-4 py-3 text-sm text-white outline-none placeholder:text-white/30 focus:border-primary" placeholder="Describe medium, diameter, pressure, temperature, approval expectations and installation context."></textarea>
          </label>

          <div class="flex flex-col gap-4 sm:flex-row">
            <button type="button" class="inline-flex justify-center border border-primary bg-primary px-6 py-4 font-display text-xs font-semibold uppercase tracking-[0.18em] text-background transition hover:bg-primary/90">
              Submit RFQ
            </button>
            <div class="flex items-center text-sm text-white/55">
              Your information is secure and will not be shared.
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
