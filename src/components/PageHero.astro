---
const { eyebrow, title, description } = Astro.props;
---

<section class="border-b border-primary/10 bg-surface/50 py-20">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <p class="font-mono text-[10px] uppercase tracking-[0.28em] text-primary">{eyebrow}</p>
    <h1 class="mt-4 font-display text-5xl font-bold uppercase leading-none text-white sm:text-6xl">
      {title}
    </h1>
    <p class="mt-6 max-w-3xl text-sm leading-8 text-muted sm:text-base">{description}</p>
  </div>
</section>
