---
import SectionHeading from "./SectionHeading.astro";
import { productCategories } from "../data/home";
---

<section id="products" class="relative overflow-hidden border-t border-white/5 bg-[#0b192c] py-14 text-white md:py-24">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(0,210,255,0.08),transparent_35%)]"></div>
  <div class="relative mx-auto max-w-[1320px] px-6 lg:px-10">
    <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
      <SectionHeading
        eyebrow="Product Lines"
        title="Engineering Solutions for Critical Applications"
        description="Structured around the four equipment families international EPC teams and terminal operators search for first."
      />
      <a
        href={productCategories[0].href}
        class="inline-flex items-center gap-2 self-start border border-white/20 px-4 py-2.5 font-mono text-[11px] uppercase tracking-[0.14em] text-[#00D2FF] hover:border-[#00D2FF]/40 hover:bg-[#00D2FF]/8 sm:px-5 sm:py-3 sm:text-xs sm:tracking-[0.18em]"
      >
        View All Products
        <span>→</span>
      </a>
    </div>

    <div class="mt-9 grid gap-[3px] md:mt-16 md:grid-cols-2 xl:grid-cols-4">
      {productCategories.map((category, index) => (
        <a
          href={category.href}
          class="group relative aspect-[5/3] overflow-hidden bg-[#1E3E62] [clip-path:polygon(0_0,calc(100%-18px)_0,100%_18px,100%_100%,0_100%)] sm:aspect-[3/4] sm:[clip-path:polygon(0_0,calc(100%-24px)_0,100%_24px,100%_100%,0_100%)]"
        >
          <div class="absolute right-0 top-0 z-10 h-[18px] w-[18px] bg-[#0b192c] [clip-path:polygon(0_0,100%_100%,100%_0)] sm:h-6 sm:w-6"></div>
          <img src={category.coverImage} alt={category.title} class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-[1.08]" />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0B192C]/95 via-[#0B192C]/55 to-transparent transition duration-300 group-hover:from-[#0B192C]/98 group-hover:via-[#0B192C]/72"></div>
          <div class="absolute inset-x-0 top-0 h-0.5 origin-left scale-x-0 bg-[#00D2FF] transition duration-300 group-hover:scale-x-100"></div>
          <div class="absolute inset-x-0 bottom-0 p-5 sm:p-7">
            <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-[#00D2FF] sm:text-[11px] sm:tracking-[0.32em]">
              {String(index + 1).padStart(2, "0")} / {category.id.split("-")[0]}
            </p>
            <h3 class="mt-3 max-w-[15ch] font-display text-[22px] font-bold leading-[1.05] text-[#F1F5F9] sm:mt-4 sm:max-w-[12ch] sm:text-[28px]">
              {category.title}
            </h3>
            <p class="mt-3 hidden max-h-0 overflow-hidden text-sm leading-6 text-[#94A3B8] opacity-0 transition-all duration-300 group-hover:max-h-28 group-hover:opacity-100 sm:block">
              {category.description}
            </p>
            <div class="mt-4 flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.16em] text-[#00D2FF] transition-all duration-300 group-hover:gap-4 sm:mt-6 sm:text-[12px] sm:tracking-[0.18em]">
              <span>Explore</span>
              <span>→</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
