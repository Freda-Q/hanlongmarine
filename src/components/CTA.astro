---
const { title = 'Ready to specify a safer terminal system?', copy = 'Send process conditions, berth layout or datasheets. Hanlong can prepare a preliminary configuration and quotation package.' } = Astro.props;
---
<section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
  <div class="tech-card clip-angle grid gap-8 p-8 md:grid-cols-[1fr_auto] md:items-center lg:p-10">
    <div>
      <p class="font-display text-sm uppercase tracking-[0.28em] text-cyan">CTA / RFQ</p>
      <h2 class="mt-3 font-display text-3xl font-bold uppercase text-silver">{title}</h2>
      <p class="mt-4 max-w-3xl text-muted">{copy}</p>
    </div>
    <div class="flex flex-wrap gap-3">
      <a class="clip-angle bg-cyan px-6 py-4 font-display text-sm font-bold uppercase tracking-[0.18em] text-abyss transition hover:scale-[.98]" href="/contact/">Request Quotation</a>
      <a class="clip-angle border border-cyan/40 px-6 py-4 font-display text-sm font-bold uppercase tracking-[0.18em] text-cyan transition hover:scale-[.98]" href="/downloads/">Download Brochure</a>
    </div>
  </div>
</section>
