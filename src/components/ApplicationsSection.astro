---
import { projectCases } from "../data/home";
---

<section id="projects" class="bg-[#0b192c] py-14 text-white lg:py-20">
  <div class="mx-auto max-w-[1320px] px-6 lg:px-10">
    <div class="mx-auto flex max-w-4xl flex-col items-center text-center">
      <div class="flex items-center gap-3 sm:gap-4">
        <div class="h-px w-7 bg-[#00D2FF] sm:w-10"></div>
        <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-[#00D2FF] sm:text-[12px] sm:tracking-[0.34em]">Global Footprint</p>
      </div>
      <h2 class="mt-4 font-display text-[1.9rem] font-bold leading-[1.05] text-[#E2E8F0] sm:mt-5 sm:text-[3.1rem] sm:leading-[1.02]">
        Proven Delivery Across 30+ Countries
      </h2>
      <p class="mt-3 max-w-3xl text-[13px] leading-6 text-[#94A3B8] sm:mt-5 sm:text-[16px] sm:leading-8">
        From Southeast Asian LNG terminals to Middle Eastern oil jetties, Hanlong equipment operates in the world's most demanding marine environments.
      </p>
    </div>

    <div class="mx-auto mt-8 max-w-6xl overflow-hidden border border-white/10 bg-[#12233a] p-3 sm:mt-14 sm:p-6">
      <div class="overflow-hidden border border-white/5 bg-[#0d1a2b] p-2 sm:p-5">
        <svg viewBox="0 0 1000 500" xmlns="http://www.w3.org/2000/svg" class="h-[170px] w-full sm:h-[280px] lg:h-[340px]">
          <defs>
            <filter id="map-glow">
              <feGaussianBlur stdDeviation="3" result="coloredBlur"></feGaussianBlur>
              <feMerge>
                <feMergeNode in="coloredBlur"></feMergeNode>
                <feMergeNode in="SourceGraphic"></feMergeNode>
              </feMerge>
            </filter>
          </defs>

          <rect width="1000" height="500" fill="rgba(11,25,44,0.45)" rx="4"></rect>

          <g stroke="rgba(0,210,255,0.05)" stroke-width="0.5">
            <line x1="0" y1="125" x2="1000" y2="125"></line>
            <line x1="0" y1="250" x2="1000" y2="250"></line>
            <line x1="0" y1="375" x2="1000" y2="375"></line>
            <line x1="250" y1="0" x2="250" y2="500"></line>
            <line x1="500" y1="0" x2="500" y2="500"></line>
            <line x1="750" y1="0" x2="750" y2="500"></line>
          </g>

          <path d="M 80 80 L 200 70 L 220 120 L 200 180 L 160 200 L 120 180 L 80 160 Z" fill="rgba(30,62,98,0.6)" stroke="rgba(0,210,255,0.15)" stroke-width="1"></path>
          <path d="M 180 220 L 230 210 L 240 280 L 220 340 L 190 360 L 170 320 L 160 260 Z" fill="rgba(30,62,98,0.6)" stroke="rgba(0,210,255,0.15)" stroke-width="1"></path>
          <path d="M 420 60 L 500 55 L 510 100 L 490 130 L 450 140 L 420 120 Z" fill="rgba(30,62,98,0.6)" stroke="rgba(0,210,255,0.15)" stroke-width="1"></path>
          <path d="M 440 150 L 510 140 L 530 200 L 520 300 L 490 340 L 460 330 L 440 270 L 430 200 Z" fill="rgba(30,62,98,0.6)" stroke="rgba(0,210,255,0.15)" stroke-width="1"></path>
          <path d="M 510 60 L 750 50 L 800 100 L 780 160 L 720 180 L 650 200 L 580 190 L 530 150 L 510 100 Z" fill="rgba(30,62,98,0.6)" stroke="rgba(0,210,255,0.15)" stroke-width="1"></path>
          <path d="M 700 190 L 760 185 L 780 230 L 750 260 L 710 250 L 690 220 Z" fill="rgba(30,62,98,0.6)" stroke="rgba(0,210,255,0.15)" stroke-width="1"></path>
          <path d="M 760 290 L 870 280 L 890 350 L 860 400 L 800 410 L 760 370 L 750 320 Z" fill="rgba(30,62,98,0.6)" stroke="rgba(0,210,255,0.15)" stroke-width="1"></path>
          <path d="M 560 160 L 620 155 L 640 200 L 610 230 L 570 220 L 550 190 Z" fill="rgba(30,62,98,0.6)" stroke="rgba(0,210,255,0.15)" stroke-width="1"></path>

          <g stroke="rgba(0,210,255,0.12)" stroke-width="0.8" stroke-dasharray="4,4">
            <line x1="730" y1="155" x2="720" y2="245"></line>
            <line x1="730" y1="155" x2="640" y2="195"></line>
            <line x1="730" y1="155" x2="585" y2="185"></line>
            <line x1="730" y1="155" x2="460" y2="245"></line>
            <line x1="730" y1="155" x2="210" y2="280"></line>
          </g>

          <g filter="url(#map-glow)">
            <circle cx="730" cy="155" r="6" fill="#00D2FF" opacity="0.95"></circle>
            <circle cx="730" cy="155" r="14" fill="rgba(0,210,255,0.15)" stroke="rgba(0,210,255,0.4)" stroke-width="1"></circle>
            <text x="742" y="150" fill="#E2E8F0" font-size="10" font-family="JetBrains Mono, monospace">HQ · Zhangjiagang</text>

            <circle cx="760" cy="140" r="5" fill="#00D2FF" opacity="0.82"></circle>
            <circle cx="790" cy="135" r="5" fill="#00D2FF" opacity="0.82"></circle>
            <circle cx="720" cy="245" r="5" fill="#00D2FF" opacity="0.82"></circle>
            <circle cx="640" cy="195" r="5" fill="#00D2FF" opacity="0.82"></circle>
            <circle cx="585" cy="185" r="5" fill="#00D2FF" opacity="0.82"></circle>
            <circle cx="570" cy="195" r="5" fill="#00D2FF" opacity="0.82"></circle>
            <circle cx="460" cy="245" r="5" fill="#00D2FF" opacity="0.82"></circle>
            <circle cx="760" cy="210" r="5" fill="#00D2FF" opacity="0.82"></circle>
            <circle cx="730" cy="215" r="5" fill="#00D2FF" opacity="0.82"></circle>
            <circle cx="745" cy="255" r="5" fill="#00D2FF" opacity="0.82"></circle>
            <circle cx="210" cy="280" r="5" fill="#00D2FF" opacity="0.82"></circle>
          </g>

          <g transform="translate(20, 440)">
            <circle cx="8" cy="8" r="5" fill="#00D2FF" opacity="0.9"></circle>
            <text x="20" y="12" fill="#94A3B8" font-size="11" font-family="JetBrains Mono, monospace">Project Location</text>
            <circle cx="160" cy="8" r="5" fill="#00D2FF" opacity="0.9"></circle>
            <circle cx="160" cy="8" r="12" fill="rgba(0,210,255,0.15)" stroke="rgba(0,210,255,0.4)" stroke-width="1"></circle>
            <text x="178" y="12" fill="#94A3B8" font-size="11" font-family="JetBrains Mono, monospace">Headquarters</text>
          </g>
        </svg>
      </div>
    </div>

    <div class="mt-5 grid gap-5 lg:grid-cols-3">
      {projectCases.map((item) => (
        <article class="group relative aspect-[16/10] overflow-hidden rounded-[14px] border border-white/[0.08] bg-[#0b1626] sm:aspect-[16/10] lg:aspect-[4/2.55]">
          <img src={item.image} alt={item.title} class="h-full w-full object-cover transition duration-[600ms] ease-out group-hover:scale-[1.06]" />
          <div class="absolute inset-0 bg-gradient-to-t from-[rgba(5,13,25,0.92)] from-0% via-[rgba(5,13,25,0.58)] via-[34%] to-[rgba(5,13,25,0.01)] to-100%"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-transparent via-transparent to-white/[0.08]"></div>
          <div class="absolute inset-x-0 bottom-0 z-10 p-4 pr-16 sm:p-6 sm:pr-20">
            <p class="inline-flex items-center gap-1.5 rounded-full border border-[#65d6ff]/25 bg-[#52c9ff]/[0.12] px-2.5 py-1.5 font-mono text-[9px] font-normal uppercase tracking-[0.14em] text-[#65d6ff] sm:px-3">
              <svg aria-hidden="true" viewBox="0 0 24 24" class="h-3.5 w-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 5-8 11-8 11s-8-6-8-11a8 8 0 1 1 16 0Z"></path>
                <circle cx="12" cy="10" r="2.5"></circle>
              </svg>
              {item.location}
            </p>
            <h3 class="mt-3 font-display text-base font-semibold leading-tight text-white drop-shadow-[0_3px_12px_rgba(0,0,0,0.85)]">
              {item.title}
            </h3>
          </div>
          <div class="absolute bottom-4 right-4 z-10 flex h-9 w-9 items-center justify-center rounded-full border border-white/25 text-lg text-white/75 transition duration-300 group-hover:border-[#3ec7ff] group-hover:bg-[#3ec7ff] group-hover:text-[#06111f] sm:bottom-6 sm:right-6 sm:h-[38px] sm:w-[38px]">
            →
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
