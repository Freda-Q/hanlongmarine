---
import SectionHeading from "./SectionHeading.astro";
import { applications } from "../data/home";
---

<section id="cases" class="bg-[#040d17] py-24 text-white">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <SectionHeading
      eyebrow="Projects"
      title="Project-Oriented Terminal References"
      description="A project section that combines real industrial imagery with application-specific text gives buyers a quicker read on where Hanlong systems are deployed."
    />

    <div class="mt-14 space-y-6">
      {applications.map((item, index) => (
        <article class="grid overflow-hidden border border-white/10 bg-[#0a1825] lg:grid-cols-[0.9fr_1.1fr]">
          <figure class:list={["min-h-[280px] overflow-hidden", index % 2 === 1 ? "lg:order-2" : ""]}>
            <img src={item.image} alt={item.title} class="h-full w-full object-cover" />
          </figure>
          <div class="flex items-center p-8 lg:p-10">
            <div>
              <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-primary">Project 0{index + 1}</p>
              <h3 class="mt-4 font-display text-3xl font-bold uppercase leading-tight text-white">
                {item.title}
              </h3>
              <p class="mt-4 max-w-2xl text-sm leading-8 text-white/70">
                {item.description}
              </p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
