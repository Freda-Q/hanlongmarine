---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const {
  title = "Hanlong Marine Equipment",
  description = "Astro static website migration foundation for Hanlong Marine Equipment."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="tech-grid min-h-screen bg-background text-foreground">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
